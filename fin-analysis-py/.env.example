# Ethereum JSON-RPC endpoint. ANY provider works — paid or free, archive or full.
# Examples (pick one, don't commit real keys):
#   RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
#   RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
#   RPC_URL=https://rpc.ankr.com/eth
#   RPC_URL=https://ethereum-rpc.publicnode.com
#   RPC_URL=http://localhost:8545              # self-hosted Geth/Erigon/Reth
#   RPC_URL=http://localhost:8545              # local Anvil fork
RPC_URL=

# Optional separate archive endpoint. If unset, falls back to RPC_URL.
# Only required for Path A (daily liquidity_snapshots via historical eth_call).
# Path B (event-replay) works without archive access.
ARCHIVE_RPC_URL=

# Optional: tune per-endpoint rate limits / chunk sizes.
# Leave unset to use library defaults.
RPC_MAX_LOGS_PER_REQUEST=
RPC_INITIAL_LOG_CHUNK_BLOCKS=
RPC_RATE_LIMIT_RPS=
