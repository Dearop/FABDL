# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# XRPL Network
NEXT_PUBLIC_XRPL_NETWORK=testnet

# Demo wallet address — set this to your XRPL testnet address
# Can also be exported as a shell env var before running `npm run dev`
NEXT_PUBLIC_DEMO_WALLET_ADDRESS=rYourTestnetAddressHere

# Optional: Otsu Wallet configuration
NEXT_PUBLIC_WALLET_URL=http://localhost:5000
